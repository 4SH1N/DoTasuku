<%= link_to "Back", root_path %>
<br><br><br>

<h1><%= @task.title %></h1>
<br><br>
<p><%= @task.description %></p>
<br><br>
<p><%= @task.priority %></p>
<br><br>
<p><%= @task.due_date %></p>
<br><br><br>

<h2>Todo List</h2>

<% @task.todos.each do |todo| %>
  <%= todo.content %>
  <%= button_to "Delete ToDo", task_todo_path(@task, todo), method: :delete %>
<% end %>

<%= render "todos/form/form", task: @task, todo: @task.todos.new %>
